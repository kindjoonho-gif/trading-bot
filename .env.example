# KIS Open API credentials
# Issue at https://apiportal.koreainvestment.com/

# ============================================================
# Active environment: mock | real
# Switch this to flip which key set the app uses at startup.
# ============================================================
KIS_ENV=mock

# ----- Mock (모의투자) -----
KIS_MOCK_APP_KEY=
KIS_MOCK_APP_SECRET=
KIS_MOCK_ACCOUNT_NO=          # format: XXXXXXXX-XX

# ----- Real (실전) -----
KIS_REAL_APP_KEY=
KIS_REAL_APP_SECRET=
KIS_REAL_ACCOUNT_NO=          # format: XXXXXXXX-XX

# Optional URL overrides (defaults are baked in per KIS_ENV)
# KIS_MOCK_BASE_URL=https://openapivts.koreainvestment.com:29443
# KIS_REAL_BASE_URL=https://openapi.koreainvestment.com:9443

# Directory holding history_{mock,real}.sqlite (gitignored). Default: data/
# HISTORY_DB_DIR=data